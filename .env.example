# ==================== API配置 ====================
# DeepSeek API配置
DEFAULT_API_KEY=your-deepseek-api-key-here
DEFAULT_MODEL=deepseek-chat
DEFAULT_API_URL=https://api.deepseek.com/v1/chat/completions

# 默认API配置（用于兼容）
DEFAULT_API_KEY=your-default-api-key-here

# ==================== 模型参数配置 ====================
MAX_ITERATIONS=5
MAX_TOKENS=4096
TEMPERATURE=0.7

# ==================== 使用说明 ====================
# 1. 复制此文件为 .env
# 2. 将 your-deepseek-api-key-here 替换为你的实际API密钥
# 3. 根据需要调整其他配置参数
# 4. .env 文件不会被提交到版本控制（已在.gitignore中配置）
